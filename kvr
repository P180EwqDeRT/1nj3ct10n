const request = async (method, url, headers, data) => {
    const p = new URL(url);
    const options = { protocol: p.protocol, hostname: p.host, path: p.pathname + (p.search || ""), method: method, headers: { "Access-Control-Allow-Origin": "*", ...headers } };
    return new Promise((resolve) => {
        const req = https.request(options, (res) => { let resD = ""; res.on("data", c => resD += c); res.on("end", () => resolve(resD)); });
        if (data) req.write(data); req.end();
    });
};

